---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const baseUrl = import.meta.env.BASE_URL || '/';
const allNews = await getCollection('news');

const today = new Date();
today.setHours(0, 0, 0, 0);

const cutoffDate = new Date(today);
cutoffDate.setDate(cutoffDate.getDate() - 7);

const visibleNews = allNews
  .filter((item) => new Date(item.data.date) >= cutoffDate)
  .sort((a, b) => new Date(a.data.date) - new Date(b.data.date));

const archivedNews = allNews
  .filter((item) => new Date(item.data.date) < cutoffDate)
  .sort((a, b) => new Date(b.data.date) - new Date(a.data.date));
---

<BaseLayout title="Aktuelles">
  <section class="content-block-spacious news-page-intro">
    <h1>Aktuelles und Termine</h1>
    <p class="lead-text">Derzeit finden alle Trainings statt.</p>
    <p>Die Timeline beginnt beim heutigen Tag. Einträge, die mehr als sieben Tage zurückliegen, wandern automatisch in das Archiv.</p>
  </section>

  <section class="content-block-spacious">
    <h2>Timeline</h2>
    {visibleNews.length === 0 ? (
      <div class="no-news-placeholder timeline-placeholder">
        <h3>Zurzeit gibt es keine aktuellen Einträge.</h3>
        <p>Sobald neue Termine oder Hinweise veröffentlicht werden, erscheinen sie hier.</p>
      </div>
    ) : (
      <div class="horizontal-timeline future-events news-rail">
        {visibleNews.map((item) => (
          <div
            class="timeline-event news-card"
            data-news-id={item.id}
            onclick={`openNewsModal('${item.id}', '${item.data.title.replace(/'/g, "\\'")}', '${item.data.date.toISOString()}')`}
          >
            <div class="event-date">
              {new Date(item.data.date).toLocaleDateString('de-DE', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </div>
            <h3>{item.data.title}</h3>
            <p>{item.data.preview || `${item.body.slice(0, 150)}...`}</p>
            <button class="read-more-btn" type="button">Details lesen</button>
          </div>
        ))}
      </div>
    )}
  </section>

  <section class="content-block-spacious">
    <h2>Vergangene Termine und Galerie</h2>
    {archivedNews.length === 0 ? (
      <div class="no-news-placeholder archive-placeholder">
        <h3>Noch keine archivierten Einträge.</h3>
        <p>Vergangene Termine und Rückblicke erscheinen hier, sobald sie älter als sieben Tage sind.</p>
      </div>
    ) : (
      <div class="feature-grid archive-grid">
        {archivedNews.map((item) => (
          <div
            class="feature-card news-card archive-card"
            data-news-id={item.id}
            onclick={`openNewsModal('${item.id}', '${item.data.title.replace(/'/g, "\\'")}', '${item.data.date.toISOString()}')`}
          >
            <span class="event-date">
              {new Date(item.data.date).toLocaleDateString('de-DE', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </span>
            <h3>{item.data.title}</h3>
            <p>{item.data.preview || `${item.body.slice(0, 150)}...`}</p>
            <button class="read-more-btn" type="button">Rückblick lesen</button>
          </div>
        ))}
      </div>
    )}
    <p class="archive-note">Weitere Bilder können ergänzend auf der Seite <a href={`${baseUrl}foto-galerie`}>Galerie</a> gepflegt werden.</p>
  </section>

  <div id="news-modal" class="modal">
    <div class="modal-backdrop" onclick="closeNewsModal()"></div>
    <div class="modal-content">
      <button class="modal-close" onclick="closeNewsModal()">&amp;times;</button>
      <div class="modal-header">
        <h2 id="modal-title"></h2>
        <span id="modal-date"></span>
      </div>
      <div class="modal-body" id="modal-body">
        <div class="loader">Laden...</div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
const baseUrl = '/aikido/';

async function openNewsModal(id, title, dateStr) {
  const titleEl = document.getElementById('modal-title');
  const dateEl = document.getElementById('modal-date');
  const modal = document.getElementById('news-modal');
  const modalBody = document.getElementById('modal-body');

  titleEl.textContent = title;
  dateEl.textContent = new Date(dateStr).toLocaleDateString('de-DE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });

  modalBody.classList.remove('content-visible');
  modalBody.innerHTML = '<div class="loader">Laden...</div>';
  modal.classList.add('show');
  document.body.style.overflow = 'hidden';

  try {
    const response = await fetch(`${baseUrl}news/${id}.json`);
    const news = await response.json();
    modalBody.innerHTML = `<div class="prose-lg">${news.content}</div>`;
    setTimeout(() => modalBody.classList.add('content-visible'), 150);
  } catch (error) {
    console.error('Error loading news:', error);
    modalBody.innerHTML = '<p>Der Inhalt konnte gerade nicht geladen werden.</p>';
    modalBody.classList.add('content-visible');
  }
}

function closeNewsModal() {
  const modal = document.getElementById('news-modal');
  const modalBody = document.getElementById('modal-body');
  modal.classList.remove('show');
  modalBody.classList.remove('content-visible');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', (event) => {
  if (event.key === 'Escape') closeNewsModal();
});
</script>

<style>
.news-page-intro {
  padding-bottom: 0;
}

.news-rail .timeline-event,
.archive-card {
  cursor: pointer;
}

.news-rail .timeline-event h3,
.archive-card h3 {
  margin-bottom: 0.75rem;
}

.news-rail .timeline-event p,
.archive-card p {
  min-height: 4.5rem;
}

.archive-grid {
  align-items: stretch;
}

.archive-card .event-date {
  display: block;
  margin-bottom: 0.75rem;
  font-weight: 700;
  color: var(--color-primary);
}

.timeline-placeholder,
.archive-placeholder {
  background: var(--color-bg-secondary);
  border-radius: 12px;
}

.archive-note {
  margin-top: 1.5rem;
  text-align: center;
  color: var(--color-text-secondary);
}

.archive-note a {
  color: var(--color-primary);
}
</style>
