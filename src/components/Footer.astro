---
const baseUrl = import.meta.env.BASE_URL || '/';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-grid">
      <div class="footer-section">
        <h4>WTA Hochburg-Ach</h4>
        <ul>
          <li><a href={`${baseUrl}ueber-uns`}>Über uns</a></li>
          <li><a href={`${baseUrl}training`}>Training</a></li>
          <li><a href={`${baseUrl}trainingsplan`}>Trainingsplan</a></li>
          <li><a href={`${baseUrl}kontakt`}>Kontakt</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>Aktuelles</h4>
        <ul>
          <li><a href={`${baseUrl}news`}>Aktuelles & Termine</a></li>
          <li><a href={`${baseUrl}termine`}>Terminübersicht</a></li>
          <li><a href={`${baseUrl}foto-galerie`}>Galerie</a></li>
          <li><a href={`${baseUrl}legal`}>Impressum & Datenschutz</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>Trainingszeiten</h4>
        <ul>
          <li>Montag: 18:00 - 19:30</li>
          <li>Freitag: 16:00 - 17:00 Vertiefung</li>
          <li>Freitag: 17:00 - 18:30 Training</li>
          <li>Samstag: 10:00 - 12:00 Waffen in ungeraden Wochen</li>
        </ul>
      </div>

      <div class="footer-section">
        <h4>Kontakt</h4>
        <ul>
          <li><a href="mailto:dojo@aikido-hochburg-ach.at">dojo@aikido-hochburg-ach.at</a></li>
          <li><a href="tel:+436504600020">+43 650 4600020</a></li>
          <li>Athaler Straße 1</li>
          <li>5122 Duttendorf</li>
        </ul>

        <div class="footer-social">
          <a href="mailto:dojo@aikido-hochburg-ach.at" aria-label="E-Mail">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1 .9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <img
    src={`${baseUrl}assets/brush.svg`}
    alt=""
    class="footer-brush"
  />

  <div class="footer-bottom">
    <p>© {currentYear} Wanomichi Takemusu Aikido Hochburg-Ach</p>
    <p class="footer-tagline">Aikido - der Weg der Harmonie | 合気道</p>
  </div>
</footer>

<style>
.footer-social {
  display: flex;
  gap: 1rem;
  margin-top: 1rem;
}

.footer-social a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--color-bg-tertiary);
  color: var(--color-primary);
  transition: all 0.3s ease;
}

.footer-social a:hover {
  background: var(--color-primary);
  color: white;
  transform: translateY(-2px);
}
</style>
